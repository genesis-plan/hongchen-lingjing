/* pages/home/home.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
}

.header {
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 30rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 26rpx;
  color: #999;
}

.buildings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.building-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
  transition: all 0.3s;
  position: relative;
}

.building-card:active {
  transform: scale(0.98);
}

.building-icon {
  font-size: 64rpx;
  margin-bottom: 15rpx;
}

.building-info {
  display: flex;
  flex-direction: column;
  margin-bottom: 10rpx;
}

.building-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.building-desc {
  font-size: 24rpx;
  color: #999;
}

.building-arrow {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 40rpx;
  color: #ddd;
}

.stats-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
  margin: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}
