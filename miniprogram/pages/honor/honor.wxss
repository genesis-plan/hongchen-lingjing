/* pages/honor/honor.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
}

.header {
  padding: 20rpx 0;
  text-align: center;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.user-card {
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid white;
}

.user-info {
  text-align: center;
  margin-bottom: 30rpx;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.user-stats {
  display: flex;
  width: 100%;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.honor-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.honor-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.honor-card.locked {
  opacity: 0.6;
}

.honor-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.honor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.honor-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.honor-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.honor-date {
  font-size: 24rpx;
  color: #999;
}

.honor-badge {
  font-size: 40rpx;
  color: #28a745;
  font-weight: bold;
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

.honor-list.locked .honor-card {
  background: #f5f5f5;
}
