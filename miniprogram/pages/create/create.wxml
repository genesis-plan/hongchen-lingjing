<!--天工开物坊页面 - 技能创建-->
<view class="container">
  <view class="header">
    <view class="title">天工开物坊</view>
    <view class="subtitle">创造技能，传承智慧</view>
  </view>

  <form bindsubmit="submitSkill">
    <view class="form-section">
      <view class="section-title">基本信息</view>

      <view class="form-item">
        <text class="label">技能名称 *</text>
        <input class="input" name="name" placeholder="请输入技能名称" value="{{formData.name}}" bindinput="onInput" data-field="name" />
      </view>

      <view class="form-item">
        <text class="label">技能分类 *</text>
        <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
          <view class="picker">
            {{formData.category || '请选择分类'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">技能简介 *</text>
        <textarea class="textarea" name="description" placeholder="请简要描述这项技能" value="{{formData.description}}" bindinput="onInput" data-field="description" maxlength="200" />
        <view class="char-count">{{formData.description.length}}/200</view>
      </view>

      <view class="form-item">
        <text class="label">技能图标</text>
        <button class="upload-btn" bindtap="uploadIcon">
          <image wx:if="{{formData.icon}}" src="{{formData.icon}}" class="icon-preview" mode="aspectFill" />
          <text wx:else>上传图标</text>
        </button>
      </view>

      <view class="form-item">
        <text class="label">封面图片</text>
        <button class="upload-btn" bindtap="uploadCover">
          <image wx:if="{{formData.cover}}" src="{{formData.cover}}" class="cover-preview" mode="aspectFill" />
          <text wx:else>上传封面</text>
        </button>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">学习内容</view>

      <view class="form-item">
        <text class="label">预计学时</text>
        <input class="input" name="duration" type="number" placeholder="请输入学时数" value="{{formData.duration}}" bindinput="onInput" data-field="duration" />
      </view>

      <view class="form-item">
        <text class="label">难度等级</text>
        <picker mode="selector" range="{{difficultyLevels}}" range-key="name" bindchange="onDifficultyChange">
          <view class="picker">
            {{formData.difficulty || '请选择难度'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">学习步骤</text>
        <view class="steps-list">
          <view class="step-item" wx:for="{{formData.steps}}" wx:key="index">
            <view class="step-header">
              <text class="step-number">步骤{{index + 1}}</text>
              <button class="delete-step-btn" size="mini" bindtap="deleteStep" data-index="{{index}}">删除</button>
            </view>
            <input class="step-input" placeholder="步骤标题" value="{{item.title}}" bindinput="onStepChange" data-index="{{index}}" data-field="title" />
            <textarea class="step-content" placeholder="步骤详细说明" value="{{item.content}}" bindinput="onStepChange" data-index="{{index}}" data-field="content" />
          </view>
          <button class="add-step-btn" bindtap="addStep">+ 添加步骤</button>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">考核设置</view>

      <view class="form-item">
        <text class="label">题目数量</text>
        <input class="input" name="questionCount" type="number" placeholder="默认5道题" value="{{formData.questionCount}}" bindinput="onInput" data-field="questionCount" />
      </view>

      <view class="form-item">
        <text class="label">及格分数</text>
        <input class="input" name="passScore" type="number" placeholder="默认60分" value="{{formData.passScore}}" bindinput="onInput" data-field="passScore" />
      </view>

      <view class="form-item">
        <text class="label">考核题目</text>
        <view class="questions-list">
          <view class="question-item" wx:for="{{formData.questions}}" wx:key="index">
            <view class="question-header">
              <text class="question-number">题目{{index + 1}}</text>
              <button class="delete-question-btn" size="mini" bindtap="deleteQuestion" data-index="{{index}}">删除</button>
            </view>
            <input class="question-input" placeholder="题目内容" value="{{item.question}}" bindinput="onQuestionChange" data-index="{{index}}" data-field="question" />
            <view class="options-list">
              <input wx:for="{{item.options}}" wx:for-item="option" wx:for-index="optionIndex" class="option-input" placeholder="选项{{optionIndex + 1}}" value="{{option}}" bindinput="onOptionChange" data-index="{{index}}" data-option-index="{{optionIndex}}" />
            </view>
            <view class="correct-answer">
              <text class="label">正确答案：</text>
              <picker mode="selector" range="{{item.options}}" range-key="" bindchange="onCorrectAnswerChange" data-index="{{index}}">
                <view class="picker">
                  {{formData.questions[index].correctAnswer !== '' ? '选项 ' + (formData.questions[index].correctAnswer + 1) : '请选择'}}
                </view>
              </picker>
            </view>
          </view>
          <button class="add-question-btn" bindtap="addQuestion">+ 添加题目</button>
        </view>
      </view>
    </view>

    <view class="form-actions">
      <button class="btn btn-secondary" bindtap="saveDraft">保存草稿</button>
      <button class="btn btn-primary" form-type="submit">提交审核</button>
    </view>
  </form>
</view>
