/* pages/practice/practice.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
}

.header {
  padding: 20rpx 0;
  text-align: center;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.skill-select {
  padding: 20rpx 0;
}

.skill-option {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.skill-option:active {
  transform: scale(0.98);
}

.skill-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.skill-info {
  flex: 1;
}

.skill-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.skill-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.arrow {
  font-size: 48rpx;
  color: #ddd;
}

.practice-area {
  padding: 20rpx 0;
}

.skill-card {
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  border: 2rpx solid rgba(106,17,203,0.15);
}

.progress-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 0 40rpx;
}

.step-dot {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.step-dot.completed {
  background: #28a745;
}

.step-dot.active {
  background: linear-gradient(to right, #6a11cb, #2575fc);
  transform: scale(1.1);
}

.step-number {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.step-content {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.step-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.step-desc {
  display: block;
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
}

.step-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
  background: #f5f5f5;
}

.button-group {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.btn-primary {
  padding: 28rpx 60rpx;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-secondary {
  padding: 28rpx 60rpx;
  background: white;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 32rpx;
}

.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx;
  width: 80%;
  text-align: center;
}

.modal-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.modal-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.modal-content .btn-primary {
  width: 100%;
  margin-bottom: 20rpx;
}

.modal-content .btn-secondary {
  width: 100%;
}
