<!--星枢问道台页面 - 活动挑战-->
<view class="container">
  <view class="header">
    <view class="title">星枢问道台</view>
    <view class="subtitle">活动挑战，切磋技艺</view>
  </view>

  <view class="challenge-banner">
    <view class="banner-title">每日挑战</view>
    <view class="banner-desc">完成每日挑战，赢取丰厚奖励</view>
    <button class="banner-btn" bindtap="startDailyChallenge">开始挑战</button>
  </view>

  <view class="section-title">热门挑战</view>
  <view class="challenge-list">
    <view class="challenge-card" wx:for="{{challenges}}" wx:key="id">
      <image class="challenge-image" src="{{item.image}}" mode="aspectFill" />
      <view class="challenge-info">
        <view class="challenge-name">{{item.name}}</view>
        <view class="challenge-desc">{{item.description}}</view>
        <view class="challenge-meta">
          <text class="challenge-difficulty difficulty-{{item.difficulty}}">{{item.difficultyText}}</text>
          <text class="challenge-participants">{{item.participants}}人参与</text>
        </view>
        <view class="challenge-rewards">
          <text>奖励：{{item.rewards}}</text>
        </view>
      </view>
      <button class="join-btn" bindtap="joinChallenge" data-id="{{item.id}}" bindtap="joinChallenge">参与</button>
    </view>
  </view>

  <view class="section-title">排行榜</view>
  <view class="ranking-list">
    <view class="ranking-item" wx:for="{{rankings}}" wx:key="rank">
      <view class="ranking-num rank-{{item.rank}}">{{item.rank}}</view>
      <image class="ranking-avatar" src="{{item.avatar}}" mode="aspectFill" />
      <view class="ranking-name">{{item.name}}</view>
      <view class="ranking-score">{{item.score}}分</view>
    </view>
  </view>
</view>
