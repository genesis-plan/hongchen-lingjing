/* pages/landing/landing.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ship-icon {
  font-size: 160rpx;
  margin-top: 80rpx;
  margin-bottom: 40rpx;
  animation: float 3s infinite ease-in-out;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-30rpx);
  }
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.landing-area {
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-radius: 60rpx;
  padding: 80rpx 60rpx;
  width: 100%;
  margin-bottom: 60rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.08);
}

.welcome-text {
  font-size: 36rpx;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.anon-id {
  font-size: 32rpx;
  color: #666;
  background: rgba(106,17,203,0.1);
  padding: 20rpx 40rpx;
  border-radius: 80rpx;
  display: inline-block;
  margin: 40rpx 0;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 32rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 16rpx 56rpx rgba(106, 17, 203, 0.4);
  margin: 20rpx 0;
}

.btn-primary:active {
  opacity: 0.9;
}

.info-text {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-top: 40rpx;
}

.features {
  width: 100%;
}

.feature-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.feature-icon {
  font-size: 64rpx;
  margin-right: 30rpx;
}

.feature-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 28rpx;
  color: #999;
}
