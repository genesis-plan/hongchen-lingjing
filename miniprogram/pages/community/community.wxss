/* 群贤毕至堂页面样式 */
.container {
  height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
}

.header {
  padding: 40rpx 32rpx 24rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #a0a0a0;
}

.tabs {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #888;
  position: relative;
}

.tab.active {
  color: #fff;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 3rpx;
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
}

.create-post {
  margin-bottom: 24rpx;
}

.create-post-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 16rpx;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 32rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

.author-info {
  flex: 1;
  margin-left: 20rpx;
}

.author-name {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 8rpx;
}

.post-time {
  font-size: 24rpx;
  color: #888;
}

.post-tag {
  padding: 8rpx 20rpx;
  background: rgba(106, 17, 203, 0.3);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #e0e0e0;
}

.post-content {
  margin-bottom: 24rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.post-text {
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.post-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.post-footer {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #888;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 28rpx;
  color: #888;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.activity-card {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  overflow: hidden;
}

.activity-image {
  width: 240rpx;
  height: 240rpx;
  object-fit: cover;
}

.activity-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.activity-time,
.activity-location,
.activity-participants {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.icon {
  width: 28rpx;
  height: 28rpx;
}

.activity-status {
  margin-top: auto;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  text-align: center;
  align-self: flex-start;
}

.status-upcoming {
  background: rgba(37, 117, 252, 0.3);
  color: #2575fc;
}

.status-ongoing {
  background: rgba(106, 17, 203, 0.3);
  color: #6a11cb;
}

.status-finished {
  background: rgba(128, 128, 128, 0.3);
  color: #808080;
}

.join-btn {
  padding: 0 24rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 32rpx;
  color: #fff;
  font-size: 24rpx;
  border: none;
}

.rules-container {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.rule-intro {
  text-align: center;
  margin-bottom: 40rpx;
}

.intro-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #a0a0a0;
  line-height: 1.6;
}

.rules-list {
  margin-bottom: 40rpx;
}

.rule-item {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.rule-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #6a11cb;
  margin-bottom: 16rpx;
}

.rule-content {
  font-size: 26rpx;
  color: #e0e0e0;
  line-height: 1.8;
}

.agreement-check {
  margin-bottom: 40rpx;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-color: transparent;
}

.check-icon {
  width: 28rpx;
  height: 28rpx;
}

.agreement-text {
  font-size: 26rpx;
  color: #e0e0e0;
  flex: 1;
}

.agree-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-form {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #e0e0e0;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.picker {
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #fff;
  display: flex;
  align-items: center;
}

.upload-btn {
  width: 100%;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  color: #888;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.btn-confirm {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  color: #fff;
}
