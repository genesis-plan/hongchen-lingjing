<!--群贤毕至堂页面 - 社区治理-->
<view class="container">
  <view class="header">
    <view class="title">群贤毕至堂</view>
    <view class="subtitle">群英荟萃，共建社区</view>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'posts' ? 'active' : ''}}" bindtap="switchTab" data-tab="posts">
      社区帖子
    </view>
    <view class="tab {{activeTab === 'activities' ? 'active' : ''}}" bindtap="switchTab" data-tab="activities">
      社区活动
    </view>
    <view class="tab {{activeTab === 'rules' ? 'active' : ''}}" bindtap="switchTab" data-tab="rules">
      社区公约
    </view>
  </view>

  <!-- 社区帖子 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'posts'}}">
    <view class="create-post">
      <button class="create-post-btn" bindtap="showCreatePostModal">
        <text>+ 发布帖子</text>
      </button>
    </view>

    <view class="post-list">
      <view class="post-card" wx:for="{{posts}}" wx:key="id" bindtap="viewPost" data-id="{{item.id}}">
        <view class="post-header">
          <image class="avatar" src="{{item.author.avatar}}" mode="aspectFill" />
          <view class="author-info">
            <view class="author-name">{{item.author.name}}</view>
            <view class="post-time">{{item.time}}</view>
          </view>
          <view class="post-tag">{{item.category}}</view>
        </view>

        <view class="post-content">
          <view class="post-title">{{item.title}}</view>
          <view class="post-text">{{item.content}}</view>
          <image wx:if="{{item.image}}" class="post-image" src="{{item.image}}" mode="aspectFill" />
        </view>

        <view class="post-footer">
          <view class="action-item">
            <image src="/images/like-icon.png" class="action-icon" />
            <text>{{item.likeCount}}</text>
          </view>
          <view class="action-item">
            <image src="/images/comment-icon.png" class="action-icon" />
            <text>{{item.commentCount}}</text>
          </view>
          <view class="action-item">
            <image src="/images/share-icon.png" class="action-icon" />
            <text>分享</text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMorePosts}}" bindtap="loadMorePosts">
      加载更多
    </view>
  </scroll-view>

  <!-- 社区活动 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'activities'}}">
    <view class="activity-list">
      <view class="activity-card" wx:for="{{activities}}" wx:key="id">
        <image class="activity-image" src="{{item.image}}" mode="aspectFill" />
        <view class="activity-info">
          <view class="activity-title">{{item.title}}</view>
          <view class="activity-time">
            <image src="/images/time-icon.png" class="icon" />
            <text>{{item.time}}</text>
          </view>
          <view class="activity-location">
            <image src="/images/location-icon.png" class="icon" />
            <text>{{item.location}}</text>
          </view>
          <view class="activity-participants">
            <image src="/images/user-icon.png" class="icon" />
            <text>{{item.participantCount}}/{{item.maxParticipants}}</text>
          </view>
          <view class="activity-status status-{{item.status}}">{{item.statusText}}</view>
        </view>
        <button class="join-btn" bindtap="joinActivity" data-id="{{item.id}}" wx:if="{{item.status !== 'finished'}}">
          {{item.status === 'joined' ? '已报名' : '立即报名'}}
        </button>
      </view>
    </view>
  </scroll-view>

  <!-- 社区公约 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'rules'}}">
    <view class="rules-container">
      <view class="rule-intro">
        <view class="intro-title">社区宗旨</view>
        <view class="intro-text">弘扬传统文化，传承传统技艺，共建和谐社区</view>
      </view>

      <view class="rules-list">
        <view class="rule-item" wx:for="{{rules}}" wx:key="index">
          <view class="rule-title">{{item.title}}</view>
          <view class="rule-content">{{item.content}}</view>
        </view>
      </view>

      <view class="agreement-check">
        <view class="check-item" wx:for="{{agreements}}" wx:key="index" bindtap="toggleAgreement" data-index="{{index}}">
          <view class="checkbox {{item.checked ? 'checked' : ''}}">
            <image wx:if="{{item.checked}}" src="/images/check-icon.png" class="check-icon" />
          </view>
          <text class="agreement-text">{{item.text}}</text>
        </view>
      </view>

      <button class="agree-btn" bindtap="agreeRules">我已阅读并同意</button>
    </view>
  </scroll-view>

  <!-- 发布帖子弹窗 -->
  <view class="modal" wx:if="{{showCreatePostModal}}" bindtap="hideCreatePostModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">发布帖子</view>
      <view class="modal-form">
        <view class="form-item">
          <text class="label">标题</text>
          <input class="input" placeholder="请输入标题" value="{{postForm.title}}" bindinput="onPostInput" data-field="title" />
        </view>
        <view class="form-item">
          <text class="label">分类</text>
          <picker mode="selector" range="{{postCategories}}" bindchange="onCategorySelect">
            <view class="picker">
              {{postForm.category || '请选择分类'}}
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">内容</text>
          <textarea class="textarea" placeholder="分享您的见解..." value="{{postForm.content}}" bindinput="onPostInput" data-field="content" />
        </view>
        <view class="form-item">
          <text class="label">图片</text>
          <button class="upload-btn" bindtap="uploadPostImage">
            <image wx:if="{{postForm.image}}" src="{{postForm.image}}" class="preview-image" mode="aspectFill" />
            <text wx:else>上传图片</text>
          </button>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn btn-cancel" bindtap="hideCreatePostModal">取消</button>
        <button class="btn btn-confirm" bindtap="submitPost">发布</button>
      </view>
    </view>
  </view>
</view>
