<!--神机枢阁页面 - AI问答-->
<view class="container">
  <view class="header">
    <view class="title">神机枢阁</view>
    <view class="subtitle">AI智慧，答疑解惑</view>
  </view>

  <view class="chat-container">
    <scroll-view class="message-list" scroll-y scroll-into-view="{{toView}}" scroll-with-animation>
      <!-- 欢迎消息 -->
      <view class="message system" wx:if="{{messages.length === 0}}">
        <view class="avatar">
          <image src="/images/ai-avatar.png" class="avatar-img" />
        </view>
        <view class="message-content">
          <text>欢迎来到神机枢阁！我是您的AI智慧助手，可以帮您解答技能学习中的任何问题。</text>
          <view class="quick-questions">
            <view class="quick-question" bindtap="askQuestion" data-question="如何更好地学习传统技艺？">如何更好地学习传统技艺？</view>
            <view class="quick-question" bindtap="askQuestion" data-question="技能传承的意义是什么？">技能传承的意义是什么？</view>
            <view class="quick-question" bindtap="askQuestion" data-question="有什么学习建议吗？">有什么学习建议吗？</view>
          </view>
        </view>
      </view>

      <!-- 消息列表 -->
      <view class="message {{item.type}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
        <view class="avatar" wx:if="{{item.type === 'ai'}}">
          <image src="/images/ai-avatar.png" class="avatar-img" />
        </view>
        <view class="message-content">
          <text>{{item.content}}</text>
        </view>
        <view class="avatar" wx:if="{{item.type === 'user'}}">
          <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" class="avatar-img" />
        </view>
      </view>

      <!-- 加载中 -->
      <view class="message ai" wx:if="{{loading}}">
        <view class="avatar">
          <image src="/images/ai-avatar.png" class="avatar-img" />
        </view>
        <view class="message-content loading">
          <view class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="input-area">
      <view class="input-wrapper">
        <input class="input" placeholder="输入您的问题..." value="{{inputText}}" bindinput="onInput" bindconfirm="send" confirm-type="send" />
        <button class="send-btn" bindtap="send" disabled="{{loading || !inputText}}">
          <image src="/images/send-icon.png" class="send-icon" />
        </button>
      </view>
      <view class="suggestions" wx:if="{{messages.length === 0}}">
        <view class="suggestion-tag" bindtap="askQuestion" data-question="介绍一下{{currentSkill || '传统手工艺'}}">介绍技能</view>
        <view class="suggestion-tag" bindtap="askQuestion" data-question="学习{{currentSkill || '传统手工艺'}}有哪些技巧？">学习技巧</view>
        <view class="suggestion-tag" bindtap="askQuestion" data-question="如何提升{{currentSkill || '传统手工艺'}}的学习效果？">提升效果</view>
      </view>
    </view>
  </view>
</view>
