<!--pages/library/library.wxml-->
<view class="container">
  <view class="header">
    <text class="title">📜 琅嬛福地</text>
    <text class="subtitle">技能图书馆</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索技能..."
      bindinput="onSearchInput"
      value="{{searchKey}}"
    />
    <text class="search-icon">🔍</text>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <text
        class="category-item {{activeCategory === item ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        bindtap="onCategoryChange"
        data-category="{{item}}">
        {{item}}
      </text>
    </view>
  </scroll-view>

  <!-- 推荐技能 -->
  <view class="section">
    <text class="section-title">推荐技能</text>
    <view class="skill-card highlight">
      <text class="skill-icon">☯️</text>
      <view class="skill-info">
        <text class="skill-name">太极·无极式</text>
        <text class="skill-desc">太极入门第一式，站桩基础，调和身心</text>
        <view class="skill-meta">
          <text class="meta-tag">入门</text>
          <text class="meta-text">1200人学习</text>
        </view>
      </view>
      <button class="btn-learn" bindtap="learnSkill" data-skill="taichi">开始学习</button>
    </view>
  </view>

  <!-- 技能列表 -->
  <view class="section">
    <text class="section-title">技能列表</text>

    <view class="skill-card" wx:for="{{filteredSkills}}" wx:key="id">
      <text class="skill-icon">{{item.icon}}</text>
      <view class="skill-info">
        <text class="skill-name">{{item.name}}</text>
        <text class="skill-desc">{{item.desc}}</text>
        <view class="skill-meta">
          <text class="meta-tag {{item.difficulty}}">{{item.difficulty}}</text>
          <text class="meta-text">{{item.learners}}人学习</text>
        </view>
      </view>
      <text class="skill-arrow">›</text>
    </view>

    <view class="empty" wx:if="{{filteredSkills.length === 0}}">
      暂无相关技能
    </view>
  </view>

  <!-- 心愿发布 -->
  <view class="wish-section">
    <text class="section-title">发布心愿</text>
    <view class="wish-tags">
      <text class="tag" wx:for="{{seedTags}}" wx:key="*this" bindtap="fillWish" data-wish="{{item}}">
        #{{item}}
      </text>
    </view>
    <textarea
      class="wish-input"
      placeholder="在此描述你想学会的技能..."
      value="{{wish}}"
      bindinput="onWishInput"
      maxlength="200"
    />
    <button class="btn-primary" bindtap="submitWish">✨ 发布心愿</button>
  </view>
</view>
