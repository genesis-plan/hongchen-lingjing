/* 两仪墟市页面样式 */
.container {
  height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
}

.header {
  padding: 40rpx 32rpx 24rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #a0a0a0;
}

.tabs {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #888;
  position: relative;
}

.tab.active {
  color: #fff;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 3rpx;
}

.badge {
  position: absolute;
  top: 12rpx;
  right: 40rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ff5050;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #fff;
}

.search-btn {
  width: 144rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
  border: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin: 32rpx 0 20rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.user-skills {
  font-size: 24rpx;
  color: #a0a0a0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.add-friend-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 24rpx;
  color: #fff;
  font-size: 24rpx;
  border: none;
}

.friend-status {
  font-size: 24rpx;
  color: #888;
  padding: 12rpx 0;
}

.online-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.online-user {
  position: relative;
  width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

.status-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #1a1a2e;
}

.status-dot.online {
  background: #52c41a;
}

.status-dot.offline {
  background: #888;
}

.friend-groups {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.group-name {
  font-size: 28rpx;
  color: #a0a0a0;
  margin-bottom: 16rpx;
}

.friend-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.friend-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.friend-info {
  flex: 1;
  margin-left: 20rpx;
}

.friend-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.friend-status {
  font-size: 24rpx;
}

.friend-status.online {
  color: #52c41a;
}

.friend-status.offline {
  color: #888;
}

.unread-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ff5050;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
}

.request-info {
  flex: 1;
  margin-left: 24rpx;
}

.request-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.request-time {
  font-size: 24rpx;
  color: #888;
}

.request-actions {
  display: flex;
  gap: 16rpx;
}

.request-actions .btn {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  border: none;
}

.btn-reject {
  background: rgba(255, 80, 80, 0.2);
  color: #ff5050;
}

.btn-accept {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 640rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.user-modal {
  max-height: 80vh;
  overflow-y: auto;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.user-detail .user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-detail .user-level {
  font-size: 26rpx;
  color: #888;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #6a11cb;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.user-bio {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1.6;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-actions .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  color: #fff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.modal-close {
  text-align: center;
  font-size: 28rpx;
  color: #888;
  padding: 16rpx;
  margin-top: 16rpx;
}

/* 聊天弹窗 */
.chat-modal {
  align-items: center;
  padding: 40rpx;
}

.chat-content {
  width: 100%;
  max-width: 640rpx;
  height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-header {
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.close-icon {
  width: 40rpx;
  height: 40rpx;
}

.chat-messages {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
}

.message.me {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  object-fit: cover;
}

.message-bubble {
  max-width: 60%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  margin: 0 16rpx;
}

.message.other .message-bubble {
  background: #f5f5f5;
  color: #333;
}

.message.me .message-bubble {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  color: #fff;
}

.chat-input {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  border-top: 2rpx solid #f0f0f0;
}

.chat-input .input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
  border: none;
}
