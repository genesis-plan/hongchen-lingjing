<!--两仪墟市页面 - 社交互动-->
<view class="container">
  <view class="header">
    <view class="title">两仪墟市</view>
    <view class="subtitle">社交广场，结交好友</view>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'square' ? 'active' : ''}}" bindtap="switchTab" data-tab="square">
      社交广场
    </view>
    <view class="tab {{activeTab === 'friends' ? 'active' : ''}}" bindtap="switchTab" data-tab="friends">
      我的好友
    </view>
    <view class="tab {{activeTab === 'requests' ? 'active' : ''}}" bindtap="switchTab" data-tab="requests">
      好友请求
      <view class="badge" wx:if="{{requestCount > 0}}">{{requestCount}}</view>
    </view>
  </view>

  <!-- 社交广场 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'square'}}">
    <view class="search-bar">
      <input class="search-input" placeholder="搜索用户..." value="{{searchKeyword}}" bindinput="onSearchInput" />
      <button class="search-btn" bindtap="searchUser">搜索</button>
    </view>

    <view class="section-title">推荐好友</view>
    <view class="user-list">
      <view class="user-card" wx:for="{{recommendedUsers}}" wx:key="userId">
        <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-info">
          <view class="user-name">{{item.nickName}}</view>
          <view class="user-level">等级：{{item.level || '入门'}}</view>
          <view class="user-skills">擅长：{{item.skills || '暂无'}}</view>
        </view>
        <button class="add-friend-btn" bindtap="addFriend" data-user="{{item}}" wx:if="{{!item.isFriend}}">
          添加好友
        </button>
        <view class="friend-status" wx:else>已是好友</view>
      </view>
    </view>

    <view class="section-title">在线用户</view>
    <view class="online-list">
      <view class="online-user" wx:for="{{onlineUsers}}" wx:key="userId" bindtap="viewUser" data-user="{{item}}">
        <image class="avatar-small" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="status-dot online"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 我的好友 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'friends'}}">
    <view class="friend-groups">
      <view class="group-item" wx:for="{{friendGroups}}" wx:key="name">
        <view class="group-name">{{item.name}} ({{item.users.length}})</view>
        <view class="friend-list">
          <view class="friend-item" wx:for="{{item.users}}" wx:for-item="friend" wx:key="userId" bindtap="openChat" data-friend="{{friend}}">
            <image class="avatar" src="{{friend.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
            <view class="friend-info">
              <view class="friend-name">{{friend.nickName}}</view>
              <view class="friend-status {{friend.online ? 'online' : 'offline'}}">
                {{friend.online ? '在线' : '离线'}}
              </view>
            </view>
            <view class="unread-badge" wx:if="{{friend.unreadCount > 0}}">{{friend.unreadCount}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{friendGroups.length === 0}}">
      <image src="/images/empty-friends.png" class="empty-icon" />
      <text class="empty-text">暂无好友，去社交广场结识新朋友吧</text>
    </view>
  </scroll-view>

  <!-- 好友请求 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'requests'}}">
    <view class="request-list">
      <view class="request-item" wx:for="{{friendRequests}}" wx:key="id">
        <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="request-info">
          <view class="request-name">{{item.nickName}}</view>
          <view class="request-time">{{item.time}}</view>
        </view>
        <view class="request-actions">
          <button class="btn btn-reject" bindtap="rejectRequest" data-id="{{item.id}}">拒绝</button>
          <button class="btn btn-accept" bindtap="acceptRequest" data-id="{{item.id}}" data-user="{{item}}">同意</button>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{friendRequests.length === 0}}">
      <image src="/images/empty-request.png" class="empty-icon" />
      <text class="empty-text">暂无好友请求</text>
    </view>
  </scroll-view>

  <!-- 查看用户弹窗 -->
  <view class="modal" wx:if="{{showUserModal}}" bindtap="closeUserModal">
    <view class="modal-content user-modal" catchtap="stopPropagation">
      <view class="user-header">
        <image class="user-avatar" src="{{currentUser.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-detail">
          <view class="user-name">{{currentUser.nickName}}</view>
          <view class="user-level">等级：{{currentUser.level || '入门'}}</view>
        </view>
      </view>
      <view class="user-stats">
        <view class="stat-item">
          <text class="stat-value">{{currentUser.skillCount || 0}}</text>
          <text class="stat-label">掌握技能</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{currentUser.honorCount || 0}}</text>
          <text class="stat-label">获得荣誉</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{currentUser.friendCount || 0}}</text>
          <text class="stat-label">好友数量</text>
        </view>
      </view>
      <view class="user-bio">
        <text>{{currentUser.bio || '这个人很懒，什么都没写'}}</text>
      </view>
      <view class="modal-actions">
        <button class="btn btn-primary" bindtap="addFriend" data-user="{{currentUser}}" wx:if="{{!currentUser.isFriend}}">添加好友</button>
        <button class="btn btn-secondary" bindtap="sendMessage" data-user="{{currentUser}}" wx:if="{{currentUser.isFriend}}">发消息</button>
      </view>
      <view class="modal-close" bindtap="closeUserModal">关闭</view>
    </view>
  </view>

  <!-- 聊天弹窗 -->
  <view class="modal chat-modal" wx:if="{{showChatModal}}" bindtap="closeChatModal">
    <view class="chat-content" catchtap="stopPropagation">
      <view class="chat-header">
        <text>{{chattingFriend.nickName}}</text>
        <image src="/images/close-icon.png" class="close-icon" bindtap="closeChatModal" />
      </view>
      <scroll-view class="chat-messages" scroll-y scroll-into-view="{{chatToView}}">
        <view class="message {{item.type}}" wx:for="{{chatMessages}}" wx:key="index" id="msg-{{index}}">
          <image class="message-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view class="message-bubble">{{item.content}}</view>
        </view>
      </scroll-view>
      <view class="chat-input">
        <input class="input" placeholder="输入消息..." value="{{chatInput}}" bindinput="onChatInput" bindconfirm="sendChatMessage" />
        <button class="send-btn" bindtap="sendChatMessage">发送</button>
      </view>
    </view>
  </view>
</view>
