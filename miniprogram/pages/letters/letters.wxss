/* 青鸟星驿页面样式 */
.container {
  height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  flex-direction: column;
}

.header {
  padding: 40rpx 32rpx 24rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #a0a0a0;
}

.tabs {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #888;
  position: relative;
}

.tab.active {
  color: #fff;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 3rpx;
}

.content {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.letter-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.letter-card {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  align-items: center;
}

.letter-status {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.letter-status.unread {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
}

.letter-status.read {
  background: rgba(255, 255, 255, 0.1);
}

.letter-icon {
  width: 40rpx;
  height: 40rpx;
}

.letter-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.letter-sender {
  font-size: 28rpx;
  color: #6a11cb;
  margin-bottom: 8rpx;
}

.letter-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.letter-preview {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.letter-time {
  font-size: 24rpx;
  color: #666;
}

.delete-btn {
  padding: 8rpx 16rpx;
  background: rgba(255, 80, 80, 0.2);
  color: #ff5050;
  font-size: 24rpx;
  border: none;
  border-radius: 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(106, 17, 203, 0.4);
  z-index: 100;
}

.fab-icon {
  width: 60rpx;
  height: 60rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-form {
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #e0e0e0;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.picker {
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #fff;
  display: flex;
  align-items: center;
}

.cards-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.card-option {
  flex: 1;
  min-width: calc(33.33% - 12rpx);
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.card-option.selected {
  border-color: #6a11cb;
  background: rgba(106, 17, 203, 0.2);
}

.card-preview {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #e0e0e0;
  border-radius: 8rpx;
}

.card-normal {
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
  color: #333;
}

.card-elegant {
  background: linear-gradient(135deg, #ffe4e1 0%, #ffd1d1 100%);
  color: #6a1a1a;
}

.card-festival {
  background: linear-gradient(135deg, #fffacd 0%, #ffe4b5 100%);
  color: #8b4513;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.btn-primary {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  color: #fff;
}

.modal-close {
  text-align: center;
  font-size: 28rpx;
  color: #888;
  padding: 16rpx;
}

/* 读信弹窗 */
.letter-modal {
  align-items: center;
  padding: 40rpx;
}

.letter-content {
  width: 100%;
  max-width: 640rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.letter-header {
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  padding: 40rpx 32rpx;
  text-align: center;
}

.letter-content .letter-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.letter-sender {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.letter-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.letter-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
  min-height: 400rpx;
}

.letter-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
}

.letter-footer {
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #f0f0f0;
  display: flex;
  gap: 16rpx;
}

.btn-reply {
  flex: 2;
  height: 80rpx;
  background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  border: none;
}

.btn-close {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  color: #333;
  font-size: 28rpx;
  border: none;
}
