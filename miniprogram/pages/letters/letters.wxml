<!--青鸟星驿页面 - 时空信件-->
<view class="container">
  <view class="header">
    <view class="title">青鸟星驿</view>
    <view class="subtitle">穿越时空的信笺</view>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'receive' ? 'active' : ''}}" bindtap="switchTab" data-tab="receive">
      收信箱
    </view>
    <view class="tab {{activeTab === 'sent' ? 'active' : ''}}" bindtap="switchTab" data-tab="sent">
      已发送
    </view>
    <view class="tab {{activeTab === 'draft' ? 'active' : ''}}" bindtap="switchTab" data-tab="draft">
      草稿箱
    </view>
  </view>

  <!-- 收信箱 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'receive'}}">
    <view class="letter-list">
      <view class="letter-card" wx:for="{{receivedLetters}}" wx:key="id" bindtap="readLetter" data-letter="{{item}}">
        <view class="letter-status {{item.read ? 'read' : 'unread'}}">
          <image src="/images/letter-icon.png" class="letter-icon" />
        </view>
        <view class="letter-info">
          <view class="letter-sender">{{item.senderName}}</view>
          <view class="letter-title">{{item.title}}</view>
          <view class="letter-preview">{{item.preview}}</view>
          <view class="letter-time">{{item.time}}</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{receivedLetters.length === 0}}">
      <image src="/images/empty-letter.png" class="empty-icon" />
      <text class="empty-text">暂无信件</text>
    </view>
  </scroll-view>

  <!-- 已发送 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'sent'}}">
    <view class="letter-list">
      <view class="letter-card" wx:for="{{sentLetters}}" wx:key="id" bindtap="readLetter" data-letter="{{item}}">
        <view class="letter-status read">
          <image src="/images/sent-icon.png" class="letter-icon" />
        </view>
        <view class="letter-info">
          <view class="letter-sender">收信人：{{item.receiverName}}</view>
          <view class="letter-title">{{item.title}}</view>
          <view class="letter-preview">{{item.preview}}</view>
          <view class="letter-time">{{item.time}}</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{sentLetters.length === 0}}">
      <image src="/images/empty-letter.png" class="empty-icon" />
      <text class="empty-text">暂无已发送信件</text>
    </view>
  </scroll-view>

  <!-- 草稿箱 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'draft'}}">
    <view class="letter-list">
      <view class="letter-card" wx:for="{{draftLetters}}" wx:key="id" bindtap="editDraft" data-draft="{{item}}">
        <view class="letter-status read">
          <image src="/images/draft-icon.png" class="letter-icon" />
        </view>
        <view class="letter-info">
          <view class="letter-title">{{item.title || '无标题'}}</view>
          <view class="letter-preview">{{item.preview || '无内容'}}</view>
          <view class="letter-time">{{item.time}}</view>
        </view>
        <button class="delete-btn" catchtap="deleteDraft" data-id="{{item.id}}">删除</button>
      </view>
    </view>

    <view class="empty-state" wx:if="{{draftLetters.length === 0}}">
      <image src="/images/empty-letter.png" class="empty-icon" />
      <text class="empty-text">暂无草稿</text>
    </view>
  </scroll-view>

  <!-- 写信按钮 -->
  <view class="fab" bindtap="showWriteModal">
    <image src="/images/write-icon.png" class="fab-icon" />
  </view>

  <!-- 写信弹窗 -->
  <view class="modal" wx:if="{{showWriteModal}}" bindtap="hideWriteModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">{{editingDraft ? '编辑草稿' : '写一封信'}}</view>
      <view class="modal-form">
        <view class="form-item">
          <text class="label">收信人</text>
          <input class="input" placeholder="输入用户名或ID" value="{{letterForm.receiver}}" bindinput="onInput" data-field="receiver" />
        </view>
        <view class="form-item">
          <text class="label">信件标题</text>
          <input class="input" placeholder="给这封信起个标题" value="{{letterForm.title}}" bindinput="onInput" data-field="title" />
        </view>
        <view class="form-item">
          <text class="label">信件内容</text>
          <textarea class="textarea" placeholder="写下你的心声..." value="{{letterForm.content}}" bindinput="onInput" data-field="content" />
          <view class="char-count">{{letterForm.content.length}}/500</view>
        </view>
        <view class="form-item">
          <text class="label">发送时间</text>
          <picker mode="selector" range="{{timeOptions}}" range-key="name" bindchange="onTimeSelect">
            <view class="picker">
              {{letterForm.sendTimeText || '立即发送'}}
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="label">添加祝福卡片</text>
          <view class="cards-list">
            <view class="card-option {{letterForm.cardType === 'normal' ? 'selected' : ''}}" bindtap="selectCard" data-type="normal">
              <view class="card-preview card-normal">普通信笺</view>
            </view>
            <view class="card-option {{letterForm.cardType === 'elegant' ? 'selected' : ''}}" bindtap="selectCard" data-type="elegant">
              <view class="card-preview card-elegant">雅致信笺</view>
            </view>
            <view class="card-option {{letterForm.cardType === 'festival' ? 'selected' : ''}}" bindtap="selectCard" data-type="festival">
              <view class="card-preview card-festival">节日信笺</view>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn btn-secondary" bindtap="saveDraft">保存草稿</button>
        <button class="btn btn-primary" bindtap="sendLetter">发送</button>
      </view>
      <view class="modal-close" bindtap="hideWriteModal">取消</view>
    </view>
  </view>

  <!-- 读信弹窗 -->
  <view class="modal letter-modal" wx:if="{{showReadModal}}" bindtap="closeReadModal">
    <view class="letter-content" catchtap="stopPropagation">
      <view class="letter-header">
        <view class="letter-title">{{currentLetter.title}}</view>
        <view class="letter-sender">{{currentLetter.senderName || '我'}} → {{currentLetter.receiverName || '我'}}</view>
        <view class="letter-date">{{currentLetter.date}}</view>
      </view>
      <scroll-view class="letter-body" scroll-y>
        <text class="letter-text">{{currentLetter.content}}</text>
      </scroll-view>
      <view class="letter-footer">
        <button class="btn btn-reply" bindtap="replyLetter">回复</button>
        <button class="btn btn-close" bindtap="closeReadModal">关闭</button>
      </view>
    </view>
  </view>
</view>
