/* pages/space/space.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
}

.header {
  padding: 20rpx 0;
  text-align: center;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.character-section {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.character-preview {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-radius: 20rpx;
}

.character-avatar {
  position: relative;
  margin-right: 30rpx;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.avatar-decoration {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(106, 17, 203, 0.4);
}

.decoration-icon {
  font-size: 28rpx;
}

.character-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.character-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.character-id {
  font-size: 24rpx;
  color: #999;
}

.character-edit {
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.edit-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 30rpx;
}

.part-section {
  margin-bottom: 40rpx;
}

.part-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.part-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.part-option {
  padding: 20rpx 30rpx;
  background: #f8fafc;
  border: 3rpx solid #e0e0e0;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.part-option.selected {
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-color: #6a11cb;
  color: #6a11cb;
  font-weight: bold;
}

.btn-primary {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.btn-secondary {
  width: 100%;
  padding: 32rpx;
  background: white;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.footprint-section {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.footprint-card {
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  min-height: 200rpx;
}

.footprint-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}
