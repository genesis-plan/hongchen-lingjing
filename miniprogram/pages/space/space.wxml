<!--pages/space/space.wxml-->
<view class="container">
  <view class="header">
    <text class="title">🪷 芥子藏虚</text>
    <text class="subtitle">个人空间</text>
  </view>

  <!-- 灵相展示 -->
  <view class="character-section">
    <text class="section-title">你的灵相</text>
    <view class="character-preview">
      <view class="character-avatar">
        <image class="avatar-image" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="avatar-decoration">
          <text class="decoration-icon">{{selectedParts.hanfu ? '👘' : '?'}}</text>
        </view>
      </view>
      <view class="character-info">
        <text class="character-name">{{userInfo.nickName}}</text>
        <text class="character-id">{{userInfo.userId}}</text>
      </view>
    </view>

    <!-- 灵相编辑 -->
    <view class="character-edit">
      <text class="edit-title">定制灵相</text>

      <view class="part-section">
        <text class="part-label">服饰</text>
        <view class="part-options">
          <view class="part-option {{selectedParts.hanfu === '齐胸襦裙' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="hanfu"
                data-value="齐胸襦裙">
            👘 齐胸襦裙
          </view>
          <view class="part-option {{selectedParts.hanfu === '圆领袍' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="hanfu"
                data-value="圆领袍">
            🎽 圆领袍
          </view>
          <view class="part-option {{selectedParts.hanfu === '直裾深衣' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="hanfu"
                data-value="直裾深衣">
            🧥 直裾深衣
          </view>
        </view>
      </view>

      <view class="part-section">
        <text class="part-label">配饰</text>
        <view class="part-options">
          <view class="part-option {{selectedParts.accessory === '机械发簪' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="accessory"
                data-value="机械发簪">
            🎀 机械发簪
          </view>
          <view class="part-option {{selectedParts.accessory === '古玉佩' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="accessory"
            data-value="古玉佩">
            💎 古玉佩
          </view>
          <view class="part-option {{selectedParts.accessory === '香囊' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="accessory"
            data-value="香囊">
            🎒 香囊
          </view>
        </view>
      </view>

      <view class="part-section">
        <text class="part-label">纹饰</text>
        <view class="part-options">
          <view class="part-option {{selectedParts.pattern === '云纹数据流' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="pattern"
                data-value="云纹数据流">
            ☁️ 云纹数据流
          </view>
          <view class="part-option {{selectedParts.pattern === '赛博花纹' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="pattern"
                data-value="赛博花纹">
            ✨ 赛博花纹
          </view>
          <view class="part-option {{selectedParts.pattern === '古朴纹理' ? 'selected' : ''}}"
                bindtap="selectPart"
                data-type="pattern"
                data-value="古朴纹理">
            🏛️ 古朴纹理
          </view>
        </view>
      </view>

      <button class="btn-primary" bindtap="saveCharacter">保存灵相</button>
    </view>
  </view>

  <!-- 足迹故事 -->
  <view class="footprint-section">
    <text class="section-title">灵境足迹</text>
    <view class="footprint-card">
      <text class="footprint-text">{{footprintStory}}</text>
    </view>
    <button class="btn-secondary" bindtap="generateFootprint">生成足迹故事</button>
  </view>
</view>
