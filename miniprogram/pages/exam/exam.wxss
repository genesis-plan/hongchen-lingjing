/* pages/exam/exam.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
}

.header {
  padding: 20rpx 0;
  text-align: center;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.exam-list {
  padding: 20rpx 0;
}

.exam-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.exam-card:active {
  transform: scale(0.98);
}

.exam-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.exam-info {
  flex: 1;
}

.exam-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.exam-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.exam-status {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background: #e0e0e0;
  color: #666;
}

.arrow {
  font-size: 48rpx;
  color: #ddd;
}

.progress-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 30rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.question-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
}

.question-number {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.question-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  background: #f8fafc;
  border: 3rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  background: linear-gradient(145deg, #f9f5ff, #f0f0ff);
  border-color: #6a11cb;
}

.option-label {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: white;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-label {
  background: #6a11cb;
  border-color: #6a11cb;
  color: white;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.button-group {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.btn-primary {
  padding: 28rpx 60rpx;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  color: white;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-secondary {
  padding: 28rpx 60rpx;
  background: white;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 20rpx;
  font-size: 32rpx;
}

.result-area {
  padding: 40rpx 0;
}

.result-card {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.08);
}

.result-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.result-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-score {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.result-detail {
  margin-bottom: 40rpx;
}

.certificate {
  background: linear-gradient(145deg, #fff9e6, #fff3cd);
  border: 3rpx solid #ffc107;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cert-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #856404;
}

.cert-skill {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.cert-user, .cert-date, .cert-seal {
  font-size: 26rpx;
  color: #666;
}

.result-card .btn-primary {
  width: 100%;
  margin-bottom: 20rpx;
}

.result-card .btn-secondary {
  width: 100%;
}
