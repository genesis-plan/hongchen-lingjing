/**app.wxss**/
page {
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
  min-height: 100vh;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 通用样式 */
.container {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  min-height: 100vh;
}

.btn-primary {
  background: linear-gradient(to right, #6a11cb, #2575fc);
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 28rpx 64rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 28rpx rgba(106, 17, 203, 0.4);
}

.btn-primary:active {
  opacity: 0.9;
}

.card {
  background: white;
  border-radius: 36rpx;
  padding: 50rpx;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(106,17,203,0.15);
  margin: 40rpx 0;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  text-align: center;
  background: linear-gradient(to right, #6a11cb, #2575fc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 30rpx;
}

.subtitle {
  font-size: 32rpx;
  text-align: center;
  color: #666;
  margin-bottom: 60rpx;
}

/* 输入框样式 */
.input-box {
  width: 100%;
  padding: 36rpx;
  border: 4rpx solid #ddd;
  border-radius: 24rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
  background: #fafafa;
}

.input-box:focus {
  border-color: #6a11cb;
  background: white;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 20rpx 40rpx;
  background: #e8f4ff;
  border-radius: 100rpx;
  font-size: 28rpx;
  margin: 12rpx;
  border: 2rpx solid #c2e0ff;
  transition: all 0.3s;
}

.tag:active {
  background: #c2e0ff;
  transform: scale(1.05);
}

/* 列表项样式 */
.list-item {
  background: #f8fafc;
  border-left: 10rpx solid #6a11cb;
  padding: 40rpx;
  margin-bottom: 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx;
  color: #999;
}

/* 状态徽章 */
.status-pending {
  color: #999;
  background: #f0f0f0;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-completed {
  color: white;
  background: #28a745;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
